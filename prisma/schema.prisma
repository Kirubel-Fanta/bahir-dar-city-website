// Postgres (Neon), used both locally and in production so there's no
// dev/prod drift. `url` is the pooled (PgBouncer) connection string used at
// runtime; `directUrl` is the unpooled connection used only for migrations.
// Neon's project dashboard gives you both under "Connection Details".
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  BUSINESS_OWNER
  MODERATOR
  USER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())

  accounts  Account[]
  sessions  Session[]
  businesses Business[]
  reviews   Review[]
  photos    Photo[]
  events    Event[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  icon      String?
  group     String
  businesses Business[]
}

model Business {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])
  neighborhood String?
  address      String?
  lat          Float?
  lng          Float?
  phone        String?
  email        String?
  website      String?
  heroImage    String
  gallery      String   @default("[]")
  openingHours String   @default("{}")
  priceRange   String?
  rating       Float    @default(0)
  reviewCount  Int      @default(0)
  featured     Boolean  @default(false)
  trending     Boolean  @default(false)
  isOpenNow    Boolean  @default(true)
  ownerId      String?
  owner        User?    @relation(fields: [ownerId], references: [id])
  reviews      Review[]
  createdAt    DateTime @default(now())
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  comment    String
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  category    String
  poster      String
  location    String
  startsAt    DateTime
  endsAt      DateTime?
  organizer   String?
  ticketUrl   String?
  approved    Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

model Article {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String
  content       String
  category      String
  featuredImage String
  author        String
  readingTime   Int      @default(4)
  publishedAt   DateTime @default(now())
}

model Attraction {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  heroImage   String
  category    String
  entryFee    String?
  lat         Float?
  lng         Float?
}

model Photo {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  width     Int      @default(3)
  height    Int      @default(4)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Neighborhood {
  id          String @id @default(cuid())
  name        String
  slug        String @unique
  description String
  image       String
  lat         Float?
  lng         Float?
}

model Job {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  company        String
  description    String
  category       String
  type           String // Full-time, Part-time, Contract, Internship
  location       String
  salaryMin      Int?
  salaryMax      Int?
  experience     String? // Entry, Mid, Senior
  applyEmail     String?
  applyUrl       String?
  isOpen         Boolean  @default(true)
  postedAt       DateTime @default(now())
}

model Property {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  propertyType String // House, Apartment, Villa, Land, Commercial, Office
  listingType  String // Rent, Sale
  price        Int
  bedrooms     Int?
  bathrooms    Int?
  areaSqm      Int?
  location     String
  image        String
  agentName    String?
  agentPhone   String?
  createdAt    DateTime @default(now())
}

model MarketplaceListing {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  category    String // Cars, Phones, Furniture, Electronics, Clothing, Bicycles, Books, Appliances
  condition   String // New, Like New, Used
  price       Int
  location    String
  image       String
  sellerName  String
  sellerPhone String?
  createdAt   DateTime @default(now())
}
